{
  "viewport": {
    "pageOverlapLines": 20,
    "minPageScrollLines": 3
  },
  "editor": {
    "position": "top"
  },
  "header": {
    "mode": "compact",
    "title": "pi-phone-3gs",
    "subtitle": "touch shell"
  },
  "utilityOverlay": {
    "autoOpenOnEnable": false,
    "keepOpenAfterButtonActivation": true
  },
  "promptMirror": {
    "enabled": false,
    "placeholder": "(prompt empty)",
    "prefix": " > "
  },
  "render": {
    "buttonGap": 1,
    "leadingColumns": 1
  },
  "inputs": {
    "modelCycle": "\u0010",
    "followUp": "\u001b\r"
  },
  "logging": {
    "tailLines": 80
  }
}
